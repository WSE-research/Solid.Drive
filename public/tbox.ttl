    rdfs:label "Video object";
    rdfs:subClassOf schema:MediaObject.
schema:AudioObject a sh:NodeShape, rdfs:Class;
    rdfs:label "Audio object";
    rdfs:subClassOf schema:MediaObject.
schema:TextDigitalDocument a sh:NodeShape, rdfs:Class;
    rdfs:label "Text digital document";
    rdfs:subClassOf schema:DigitalDocument.
schema:SpreadsheetDigitalDocument a sh:NodeShape, rdfs:Class;
    rdfs:label "Spreadsheet digital document";
    rdfs:subClassOf schema:DigitalDocument.
schema:CreativeWork a sh:NodeShape, rdfs:Class;
    rdfs:label "Creative work";
    rdfs:subClassOf schema:Thing;
    sh:property schema:CreativeWork-dateModified, schema:CreativeWork-encodingFormat, schema:CreativeWork-isPartOf, schema:CreativeWork-publisher.
schema:Thing a sh:NodeShape, rdfs:Class;
