schema:DigitalDocument a sh:NodeShape, rdfs:Class;
    rdfs:label "Digital document";
    rdfs:subClassOf schema:CreativeWork.
schema:MediaObject a sh:NodeShape, rdfs:Class;
    rdfs:label "Media object";
    rdfs:subClassOf schema:CreativeWork;
    sh:property schema:MediaObject-contentSize, schema:MediaObject-encodingFormat, schema:MediaObject-uploadDate.
schema:ImageObject a sh:NodeShape, rdfs:Class;
    rdfs:label "Image object";
    rdfs:subClassOf schema:MediaObject.
