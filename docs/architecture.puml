@startuml architecture
title solid.drive Architecture

!theme plain
skinparam defaultFontName sans-serif
skinparam defaultFontSize 13
skinparam classAttributeIconSize 0
skinparam backgroundColor White
skinparam linetype ortho

skinparam class {
  BackgroundColor White
  BorderColor #555555
  FontColor #111111
  HeaderBackgroundColor #EEEEEE
}

skinparam package {
  BackgroundColor #F8F8F8
  BorderColor #AAAAAA
  FontColor #333333
  FontStyle Bold
}

left to right direction

package "Browser" {

  class App <<component>>

  class Header <<component>> {
    +login(issuer: string)
    +logout()
  }

  class FileExplorer <<component>> {
    +navigate(uri: string)
    +reload()
  }

  class FileUpload <<component>> {
    +submit(file, title, description)
  }

  class FileCard <<component>> {
    +download()
    +delete()
  }

  class FolderEntry <<component>> {
    +navigate(uri: string)
  }

  App -- Header
  App -- FileExplorer
  FileExplorer -- FileUpload
  FileExplorer -- FileCard
  FileExplorer -- FolderEntry
}

package "Solid Pod (user-owned)" {

  class CatalogTTL <<catalog.ttl>> {
    instanceUri a dcat:Dataset
    dcterms:conformsTo schema:ImageObject
    dcterms:conformsTo schema:VideoObject
    dcterms:conformsTo schema:AudioObject
    dcterms:conformsTo schema:TextDigitalDocument
    dcterms:conformsTo schema:SpreadsheetDigitalDocument
    dcterms:conformsTo schema:DigitalDocument
  }

  class AppContainer <<my-solid-app/>>

  class FileContainer <<file-slug/>>

  class IndexTTL <<index.ttl>> {
    rdf:type (schema.org class)
    schema:name
    schema:encodingFormat
    schema:contentSize
    schema:uploadDate
    schema:publisher
  }

  class BinaryFile <<file.ext>>

  class WebIDProfile <<profile/card>> {
    vcard:fn
    foaf:name
    dcat:catalog (optional)
  }

  AppContainer -- "1..*" FileContainer
  FileContainer -- IndexTTL
  FileContainer -- BinaryFile
  WebIDProfile -- CatalogTTL : dcat:catalog (optional pointer)
}

FileUpload .. CatalogTTL   : appends
FileUpload .. AppContainer : uploads to
FileUpload .. WebIDProfile : links catalog (first upload only)
FileCard .. FileContainer  : reads
FileCard .. CatalogTTL     : removes on delete
FileCard .. WebIDProfile   : resolves publisher name
FileExplorer .. AppContainer : browses
FileExplorer .. WebIDProfile : resolves catalog URI (profile-first)

@enduml
